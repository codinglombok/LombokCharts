{
  "root": true,
  "env": { "browser": true, "es2021": true, "node": true },
  "parserOptions": { "ecmaVersion": 2021, "sourceType": "module" },
  "extends": "eslint:recommended",
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_", "args": "none" }],
    "no-empty": "off"
  }
}
